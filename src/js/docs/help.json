[
  {"text": "📚 Kaysa Slider Documentation", "style": "color: #6c5ce7; font-weight: bold; font-size: 1.4em;"},
  {"text": "Kaysa is a flexible and customizable slider component for modern web applications.", "style": "color: #ccc; font-size: 1em;"},
  {"text": "", "style": ""},
  {"text": "🔧 Configuration Options:", "style": "color: #00b894; font-weight: bold; font-size: 1.2em;"},
  {"text": "  target: The container element where the slider will be applied. (REQUIRED)", "style": "color: #fd79a8;"},
  {"text": "  scrollSpeed: Determines the scrolling speed (value between 0.1–1). Default: 0.8 (Optional)", "style": "color: #fd79a8;"},
  {"text": "  gap: Sets the gap between items (CSS value). Default: '15px' (Optional)", "style": "color: #fd79a8;"},
  {"text": "  enhancedScrollbar: Enables/disables the custom scrollbar (true/false). Default: false (Optional)", "style": "color: #fd79a8;"},
  {"text": "  prevButtonContent: Content of the previous button. Default: '<' (Optional)", "style": "color: #fd79a8;"},
  {"text": "  nextButtonContent: Content of the next button. Default: '>' (Optional)", "style": "color: #fd79a8;"},
  {"text": "  onError: Error callback: (error, context) => {}. Default: null (Optional)", "style": "color: #fd79a8;"},
  {"text": "", "style": ""},
  {"text": "❗ Note:", "style": "color: #e17055; font-weight: bold;"},
  {"text": "  - target is a required parameter that specifies the container for the slider.", "style": ""},
  {"text": "  - All other configuration options are optional and have default values.", "style": ""},
  {"text": "", "style": ""},
  {"text": "🌓 Dark Mode Support:", "style": "color: #a29bfe; font-weight: bold; font-size: 1.1em;"},
  {"text": "  Automatically adapts when <body> has 'dark-mode' class.", "style": "color: #fd79a8;"},
  {"text": "  - Example: <body class=\"dark-mode\">", "style": ""},
  {"text": "", "style": ""},
  {"text": "📌 JavaScript Example:", "style": "color: #0984e3; font-weight: bold;"},
  {"text": "new Kaysa({", "style": ""},
  {"text": "    target: '#slider', // REQUIRED", "style": ""},
  {"text": "    scrollSpeed: 0.7,  // Optional", "style": ""},
  {"text": "    gap: '20px',       // Optional", "style": ""},
  {"text": "    enhancedScrollbar: true, // Optional", "style": ""},
  {"text": "    prevButtonContent: '←',   // Optional", "style": ""},
  {"text": "    nextButtonContent: '→'    // Optional", "style": ""},
  {"text": "});", "style": ""},
  {"text": "", "style": ""},
  {"text": "📌 HTML Attribute Example:", "style": "color: #0984e3; font-weight: bold;"},
  {"text": "<div id=\"slider\" ", "style": ""},
  {"text": "    data-kaysa-scroll-speed=\"0.7\" <!-- Scroll speed (Optional) -->", "style": ""},
  {"text": "    data-kaysa-gap=\"20px\"         <!-- Gap between items (Optional) -->", "style": ""},
  {"text": "    data-kaysa-enhanced-scrollbar=\"true\" <!-- Custom scrollbar usage (Optional) -->", "style": ""},
  {"text": "    data-kaysa-prev-button-content=\"←\"     <!-- Previous button content (Optional) -->", "style": ""},
  {"text": "    data-kaysa-next-button-content=\"→\">    <!-- Next button content (Optional) -->", "style": ""},
  {"text": "  <div>Item 1</div>", "style": ""},
  {"text": "  <div>Item 2</div>", "style": ""},
  {"text": "  <div>Item 3</div>", "style": ""},
  {"text": "  <div>Item 4</div>", "style": ""},
  {"text": "</div>", "style": ""},
  {"text": "", "style": ""},
  {"text": "🔧 API Methods:", "style": "color: #00b894; font-weight: bold; font-size: 1.2em;"},
  {"text": "  slider.add(element, index?)    — Add an element (index optional, default: end)", "style": "color: #fd79a8;"},
  {"text": "  slider.remove(index?)          — Remove an element (index optional, default: last)", "style": "color: #fd79a8;"},
  {"text": "  slider.scroll(direction)       — Scroll the slider ('left' or 'right')", "style": "color: #fd79a8;"},
  {"text": "", "style": ""},
  {"text": "❗ Note:", "style": "color: #e17055; font-weight: bold;"},
  {"text": "  - Nav buttons auto-hide when content doesn't overflow.", "style": ""},
  {"text": "  - Buttons reappear dynamically as items are added or container resizes.", "style": ""},
  {"text": "", "style": ""},
  {"text": "🌐 GitHub Repository: https://github.com/edukah/kaysa", "style": "color: #74b9ff; text-decoration: underline;"},
  {"text": "🚀 Live Demo: https://edukah.github.io/kaysa/", "style": "color: #ff7675; text-decoration: underline;"}
]